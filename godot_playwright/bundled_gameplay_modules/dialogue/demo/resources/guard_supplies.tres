[gd_resource type="Resource" script_class="DialogueLineDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/dialogue/dialogue_line_definition.gd" id="1_line_script"]

[resource]
script = ExtResource("1_line_script")
line_id = &"guard_supplies"
speaker = "Guard"
text = "Fine. Take these medical supplies."
apply_variables = {"supplies_received": true}
on_enter = {"action": "grant_supplies"}

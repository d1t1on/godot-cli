[gd_resource type="Resource" script_class="DialogueDefinition" load_steps=5 format=3]

[ext_resource type="Script" path="res://addons/dialogue/dialogue_definition.gd" id="1_dialogue_script"]
[ext_resource type="Resource" path="res://resources/dialogue_demo/guard_greet.tres" id="2_guard_greet"]
[ext_resource type="Resource" path="res://resources/dialogue_demo/guard_ask.tres" id="3_guard_ask"]

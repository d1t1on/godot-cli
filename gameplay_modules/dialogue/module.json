{
  "name": "dialogue",
  "version": "0.1.0",
  "display_name": "Dialogue",
  "description": "Resource-driven branching dialogue system for Godot projects.",
  "godot_version": ">=4.6",
  "copy": [
    {"from": "addons/dialogue", "to": "addons/dialogue"}
  ],
  "autoloads": [],
  "demo": {
    "copy": [
      {"from": "demo/scenes", "to": "scenes/dialogue_demo"},
      {"from": "demo/scripts", "to": "scripts/dialogue_demo"},
      {"from": "demo/resources", "to": "resources/dialogue_demo"},
      {"from": "tests", "to": "tests/dialogue_demo"}
    ]
  },
  "validation": {
    "commands": [
      "godot-playwright check-scripts /path/to/project res://addons/dialogue --exclude addons/godot_playwright/**",
      "godot-playwright check-resources /path/to/project res://addons/dialogue --exclude addons/godot_playwright/**"
    ]
  }
}

[gd_resource type="Resource" script_class="StatDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/stats/stat_definition.gd" id="1_stat_definition"]

[resource]
script = ExtResource("1_stat_definition")
stat_id = &"health"
